{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "./hardhat.config.ts",
    "./deploy/**/*.ts",
    "./test/**/*.ts",
    "./scripts/**/*.ts",
    "./typechain-types/**/*.ts"
  ],
  "files": [
    "./hardhat.config.ts"
  ]
}
